{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "erh:viam-chartplotter",
  "visibility": "public",
  "url": "https://github.com/erh/viam-chartplotter",
  "description": "silly chart plotter",
  "models": [
    {
      "api": "rdk:component:generic",
      "model": "erh:viam-chartplotter:chartplotter",
      "description": "Chartplotter web UI + NOAA ENC/WMS tile server. Renders S-57 vector charts with draft-keyed depth shading.",
      "markdown_link": "README.md#chartplotter"
    },
    {
      "api": "rdk:service:navigation",
      "model": "erh:viam-chartplotter:nav",
      "description": "Persistent in-memory navigation service for the chartplotter UI.",
      "markdown_link": "README.md#navigation"
    },
    {
      "api": "rdk:component:generic",
      "model": "erh:viam-chartplotter:datasync",
      "description": "Keeps the shared MongoDB 'noaa' collection current by periodically refreshing the NOAA ENC catalog and ingesting every published cell worldwide. Run on one machine; the chartplotter/tileserver read charts from Mongo.",
      "markdown_link": "README.md#datasync"
    },
    {
      "api": "rdk:component:generic",
      "model": "erh:viam-chartplotter:weathersync",
      "description": "Decodes weather forecast GRIB into the shared MongoDB 'weather' collection on an interval, so render/tile servers serve weather from Mongo instead of every instance re-fetching GRIB.",
      "markdown_link": "README.md#weathersync"
    }
  ],
  "first_run": "",
  "entrypoint": "./bin/viamchartplottermodule",
  "build": {
    "build": "make module",
    "setup": "make setup-linux",
    "arch": [
      "linux/amd64",
      "linux/arm64",
      "darwin/arm64"
    ],
    "darwin_deps" : ["touch"],
    "path": "module.tar.gz"
  },
  "applications": [
    {
      "name": "chartplotter",
      "type": "single_machine",
      "entrypoint": "dist/index.html",
      "logoPath": "dist/logo.png",
      "customizations": {
        "machinePicker": {
          "heading": "Demo Chartplotter app on Viam",
          "subheading": "https://github.com/erh/viam-chartplotter"
        }
      }
    }
  ]
}
