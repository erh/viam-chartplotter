{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "erh:viam-chartplotter",
  "visibility": "public",
  "url": "https://github.com/erh/viam-chartplotter",
  "description": "silly chart plotter",
  "models": [
    {
      "api": "rdk:component:generic",
      "model": "erh:viam-chartplotter:chartplotter"
    },
    {
      "api": "rdk:service:navigation",
      "model": "erh:viam-chartplotter:nav",
      "description": "Persistent in-memory navigation service for the chartplotter UI.",
      "markdown_link": "README.md#navigation-service"
    }
  ],
  "first_run": "",
  "entrypoint": "./bin/viamchartplottermodule",
  "build": {
    "build": "make module",
    "setup": "make setup-linux",
    "arch": ["linux/amd64", "linux/arm64", "darwin/arm64"],
    "path": "module.tar.gz"
  },
  "applications": [
    {
      "name": "chartplotter",
      "type": "single_machine",
      "entrypoint": "dist/index.html",
      "logoPath": "dist/logo.png",
      "customizations": {
        "machinePicker": {
          "heading": "Demo Chartplotter app on Viam",
          "subheading": "https://github.com/erh/viam-chartplotter"
        }
      }
    }
  ]
}
