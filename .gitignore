# --- OS / editor ---
.DS_Store
.vscode/
*~
*.#*

# --- Secrets / environment ---
.env
.env.*
!.env.example

# --- Agent / tooling ---
# Ignore local/personal agent settings, but keep shared project hooks + the
# committed SessionStart config tracked.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json

# --- Node / frontend build output ---
node_modules
/dist
/build
/.svelte-kit
/package
# generated by Tailwind
src/output.css
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# --- Go build output ---
/bin/
# cmd/ binaries when built straight into the repo root (prefer `make` -> bin/).
# Root-anchored so they don't shadow same-named source dirs (e.g. render/).
/datasync
/ecmwf-probe
/module
/osm-ingest
/run
/tileserver
/weathersync
/render-cmd
/mapsync

# --- Viam module packaging ---
module.tar.gz
.VIAM_RELOAD_ARCHIVE.tar.gz

# --- Local dev / test scratch ---
test.make
tile*.png
